{
  "speed": [
    { "if": "road_class == PRIMARY || road_class == TRUNK", "limit_to": "18" },
    { "else_if": "road_class == SECONDARY || road_class == TERTIARY", "limit_to": "20" },
    { "else_if": "road_class == RESIDENTIAL", "limit_to": "15" },
    { "else": "", "limit_to": "12" }
  ],
  "priority": [
    { "if": "road_class == CYCLEWAY", "multiply_by": "3.0" },
    { "else_if": "bike_network != MISSING", "multiply_by": "2.0" },
    { "else_if": "road_class == MOTORWAY || road_class == TRUNK", "multiply_by": "0.1" },
    { "else": "", "multiply_by": "1.0" }
  ]
}