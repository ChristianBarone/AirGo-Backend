{
  "speed": [
    { "if": "road_class == PRIMARY || road_class == TRUNK", "limit_to": "18" },
    { "if": "road_class == SECONDARY || road_class == TERTIARY", "limit_to": "20" },
    { "if": "road_class == RESIDENTIAL", "limit_to": "15" },
    { "if": "road_class == UNCLASSIFIED || road_class == SERVICE", "limit_to": "12" },
    { "if": "road_class == TRACK || road_class == FOOTWAY", "limit_to": "10" },
    { "if": "true", "limit_to": "12" }
  ],
  "priority": [
    { "if": "bike_infrastructure == DEDICATED", "multiply_by": "3.0" },
    { "if": "bike_infrastructure == LANE", "multiply_by": "2.5" },
    { "if": "bike_infrastructure == SHARED_LANE", "multiply_by": "1.8" },
    { "if": "smoothness == EXCELLENT || smoothness == GOOD", "multiply_by": "1.3" },
    { "if": "surface == ASPHALT || surface == CONCRETE", "multiply_by": "1.2" },
    { "if": "surface == GRAVEL || surface == UNPAVED", "multiply_by": "0.8" },
    { "if": "road_class == MOTORWAY || road_class == TRUNK", "multiply_by": "0.3" },
    { "if": "max_incline > 8", "multiply_by": "0.7" },
    { "if": "max_incline > 12", "multiply_by": "0.5" }
  ]
}
