{
  "speed": [
    { "if": "road_class == FOOTWAY || road_class == PEDESTRIAN", "limit_to": "12" },
    { "if": "road_class == RESIDENTIAL", "limit_to": "10" },
    { "if": "road_class == UNCLASSIFIED", "limit_to": "9" },
    { "if": "road_class == TRACK", "limit_to": "8" },
    { "if": "true", "limit_to": "10" }
  ],
  "priority": [
    { "if": "leisure == PARK || natural == WOOD || natural == GRASSLAND", "multiply_by": "3.0" },
    { "if": "road_class == FOOTWAY || foot == DESIGNATED", "multiply_by": "2.5" },
    { "if": "road_class == RESIDENTIAL", "multiply_by": "1.8" },
    { "if": "surface == ASPHALT || surface == CONCRETE", "multiply_by": "1.2" },
    { "if": "surface == WOOD || surface == PAVING_STONES", "multiply_by": "1.0" },
    { "if": "surface == GRAVEL || surface == DIRT", "multiply_by": "0.8" },
    { "if": "smoothness == EXCELLENT || smoothness == GOOD", "multiply_by": "1.4" },
    { "if": "smoothness == INTERMEDIATE", "multiply_by": "1.0" },
    { "if": "smoothness == BAD || smoothness == VERY_BAD", "multiply_by": "0.6" },
    { "if": "road_class == PRIMARY || road_class == SECONDARY", "multiply_by": "0.5" },
    { "if": "road_class == TRUNK || road_class == MOTORWAY", "multiply_by": "0.1" },
    { "if": "max_incline > 5", "multiply_by": "0.85" },
    { "if": "max_incline > 10", "multiply_by": "0.6" },
    { "if": "max_incline > 15", "multiply_by": "0.3" },
    { "if": "max_incline < -5", "multiply_by": "0.85" },
    { "if": "maxspeed > 50", "multiply_by": "0.4" }
  ]
}

